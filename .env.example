### --- База данных (смените пароль перед выкатом!) ---
POSTGRES_USER=english
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=english
POSTGRES_HOST=db
POSTGRES_PORT=5432

### --- Строка подключения. Пароль должен совпадать с POSTGRES_PASSWORD ---
DATABASE_URL=postgresql+asyncpg://english:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/english

### --- JWT. Генерация: make gen-secret (64+ случайных символов) ---
JWT_SECRET=CHANGE_ME_64_CHARS_RANDOM_SECRET
JWT_ALGORITHM=HS256
# 120 минут = 2 часа. Не держите слишком долго — токены не отзываются серверно.
JWT_EXPIRE_MINUTES=120

### --- CORS: только явные origins, '*' запрещён ---
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

### --- Публичный порт фронта (backend наружу не торчит) ---
FRONTEND_PORT=8080

### --- TTS: вариант 1 — Piper (быстрый, лёгкий, ~60 MB модель) ---
TTS_ENGINE=piper
TTS_VOICE_PIPER=en_US-amy-medium

### --- TTS: вариант 2 — Kokoro (качество выше, ~330 MB модель, нужен torch) ---
# TTS_ENGINE=kokoro
# TTS_VOICE_KOKORO=af_heart

TTS_MODELS_DIR=/app/models/tts
TTS_BATCH_CONCURRENCY=10

### --- Admin (используется ТОЛЬКО в `make create-admin`, не для авто-промоушена) ---
ADMIN_EMAIL=admin@example.com
