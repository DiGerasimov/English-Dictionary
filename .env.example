POSTGRES_USER=english
POSTGRES_PASSWORD=english
POSTGRES_DB=english
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://english:english@db:5432/english

JWT_SECRET=change-me-please-super-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

BACKEND_PORT=8000
FRONTEND_PORT=8080

# --- TTS: вариант 1 — Piper (быстрый, лёгкий, ~60 MB модель) ---
TTS_ENGINE=piper
TTS_VOICE_PIPER=en_US-amy-medium

# --- TTS: вариант 2 — Kokoro (качество выше, ~330 MB модель, нужен torch) ---
# TTS_ENGINE=kokoro
# TTS_VOICE_KOKORO=af_heart

TTS_MODELS_DIR=/app/models/tts
TTS_BATCH_CONCURRENCY=10

# Email пользователя, которому автоматически выдаются права админа при логине/регистрации
ADMIN_EMAIL=admin@example.com
